<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D0D1A">

    <!-- Top bar: settings right, achievements left -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <ImageButton
            android:id="@+id/btnAchievements"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_achievements"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Achievements"
            android:padding="10dp"/>

        <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_settings"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Settings"
            android:padding="10dp"/>
    </LinearLayout>

    <!-- Scrollable content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingTop="12dp"
            android:paddingBottom="20dp">

            <!-- Logo -->
            <FrameLayout android:layout_width="100dp" android:layout_height="100dp">
                <View android:layout_width="100dp" android:layout_height="100dp"
                    android:background="@drawable/circle_bg"/>
                <ImageView android:layout_width="44dp" android:layout_height="44dp"
                    android:layout_gravity="center" android:src="@drawable/ic_mic"/>
            </FrameLayout>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="MirrorTalk" android:textColor="#FFFFFF"
                android:textSize="36sp" android:textStyle="bold" android:layout_marginTop="16dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="AI-powered speaking confidence trainer"
                android:textColor="#7F77DD" android:textSize="13sp" android:layout_marginTop="4dp"/>

            <!-- Gamification stat row -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="12dp">

                <TextView android:id="@+id/tvSessionCount"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0 sessions" android:textColor="#555577" android:textSize="12sp"/>

                <View android:layout_width="1dp" android:layout_height="12dp"
                    android:background="#333355" android:layout_marginStart="10dp"
                    android:layout_marginEnd="10dp"/>

                <TextView android:id="@+id/tvStreak"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0 day streak" android:textColor="#FFCC44" android:textSize="12sp"
                    android:textStyle="bold"/>

                <View android:layout_width="1dp" android:layout_height="12dp"
                    android:background="#333355" android:layout_marginStart="10dp"
                    android:layout_marginEnd="10dp"/>

                <TextView android:id="@+id/tvLevel"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Level 1" android:textColor="#7F77DD" android:textSize="12sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <!-- Feature pills -->
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginTop="20dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Speech Rate" android:textColor="#7F77DD" android:textSize="12sp"
                    android:paddingTop="6dp" android:paddingBottom="6dp"
                    android:paddingStart="12dp" android:paddingEnd="12dp"
                    android:background="@drawable/pill_bg" android:layout_marginEnd="8dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Eye Contact" android:textColor="#1D9E75" android:textSize="12sp"
                    android:paddingTop="6dp" android:paddingBottom="6dp"
                    android:paddingStart="12dp" android:paddingEnd="12dp"
                    android:background="@drawable/pill_bg_green" android:layout_marginEnd="8dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Filler Words" android:textColor="#FFCC44" android:textSize="12sp"
                    android:paddingTop="6dp" android:paddingBottom="6dp"
                    android:paddingStart="12dp" android:paddingEnd="12dp"
                    android:background="@drawable/pill_bg_amber"/>
            </LinearLayout>

            <!-- Practice prompt card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:layout_marginTop="24dp"
                app:cardBackgroundColor="#1A1435"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">
                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="18dp">
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="TODAY'S PROMPT"
                            android:textColor="#7F77DD" android:textSize="11sp"
                            android:letterSpacing="0.1"/>
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnShuffle"
                            android:layout_width="wrap_content" android:layout_height="34dp"
                            android:text="Shuffle" android:textColor="#FFFFFF" android:textSize="12sp"
                            app:icon="@drawable/ic_shuffle" app:iconGravity="textStart"
                            app:iconSize="16dp" app:iconTint="#FFFFFF"
                            app:backgroundTint="#3C3489" app:cornerRadius="17dp"/>
                    </LinearLayout>
                    <TextView android:id="@+id/tvPrompt"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:textColor="#E0DFFF" android:textSize="15sp"
                        android:lineSpacingMultiplier="1.5" android:minLines="2"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Use this as your speaking topic for the next session"
                        android:textColor="#555577" android:textSize="11sp"
                        android:fontFamily="sans-serif-light"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- Action buttons pinned to bottom -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="32dp" android:paddingEnd="32dp"
        android:paddingBottom="72dp" android:paddingTop="12dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStart"
            android:layout_width="match_parent" android:layout_height="58dp"
            android:text="Start Session" android:textSize="17sp" android:textColor="#FFFFFF"
            app:icon="@drawable/ic_mic" app:iconGravity="textStart"
            app:iconSize="20dp" app:iconTint="#FFFFFF"
            app:backgroundTint="#7F77DD" app:cornerRadius="30dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnHistory"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:text="View History" android:textSize="15sp" android:textColor="#7F77DD"
            android:layout_marginTop="12dp"
            app:icon="@drawable/ic_history" app:iconGravity="textStart"
            app:iconSize="18dp" app:iconTint="#7F77DD"
            app:backgroundTint="@android:color/transparent"
            app:strokeColor="#3C3489" app:strokeWidth="1dp" app:cornerRadius="26dp"/>

    </LinearLayout>

</LinearLayout>